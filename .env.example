# Environment Configuration Example
# Copy this to .env and fill in your actual values

# Application Environment
ENV=LOCAL  # LOCAL or PROD
PORT=8001
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
STRUCTURED_LOGGING=true  # true for JSON logs, false for human-readable
WORKERS=4  # Number of gunicorn workers for production

# CORS Settings
ALLOWED_ORIGINS=*  # Comma-separated list of allowed origins

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_RETRIES=3
OPENAI_TEMPERATURE=0.3
OPENAI_TIMEOUT=100
OPENAI_MAX_FUNCTION_CALLS=10

# Database Configuration
# For Local Development
DB_USER=your_db_user
DB_PASSWORD=your_db_password  
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mindmap_db

# For Production (Google Cloud SQL)
CONNECTION_NAME=your-project:your-region:your-instance
DB_USER_PROD=your_prod_user
DB_NAME=mindmap_db

# Google Cloud Storage
RESULTS_BUCKET=mindmap-results
RESULTS_FOLDER=query_results
SAVE_TO_GCS=true

# Query Service Configuration
QUERY_MAX_RETRIES=3
MIN_DEPTH_THRESHOLD=1
LOG_TO_DB=true

# Security (if implementing authentication)
# JWT_SECRET_KEY=your_jwt_secret_key
# SESSION_SECRET=your_session_secret